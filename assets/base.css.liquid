/* ============================================
   BARKTOPIA — PLAYGROUND THEME
   Base Styles + Component Library
   ============================================ */

/* === CSS VARIABLES === */
:root {
  --color-primary: {{ settings.color_primary }};
  --color-secondary: {{ settings.color_secondary }};
  --color-accent: {{ settings.color_accent }};
  --color-mint: {{ settings.color_mint }};
  --color-bg: {{ settings.color_bg_primary }};
  --color-bg-alt: {{ settings.color_bg_secondary }};
  --color-text: {{ settings.color_text }};
  --color-text-muted: {{ settings.color_text_muted }};
  --font-heading: '{{ settings.heading_font }}', sans-serif;
  --font-body: '{{ settings.body_font }}', sans-serif;
  --max-width: {{ settings.max_width }}px;
  --radius: {{ settings.border_radius }}px;
  --body-size: {{ settings.body_size }}px;
  --heading-scale: {{ settings.heading_scale | divided_by: 100.0 }};
}

/* === RESET === */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { -webkit-text-size-adjust: 100%; scroll-behavior: auto; }
body {
  font-family: var(--font-body);
  font-size: var(--body-size);
  color: var(--color-text);
  background: var(--color-bg);
  line-height: 1.65;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
img, picture, video, svg { display: block; max-width: 100%; height: auto; }
a { color: inherit; text-decoration: none; }
button { font: inherit; cursor: pointer; border: none; background: none; }
ul, ol { list-style: none; }
h1, h2, h3, h4, h5, h6 { font-family: var(--font-heading); font-weight: 700; line-height: 1.1; }

/* === ACCESSIBILITY === */
.skip-to-content {
  position: absolute; top: -100%; left: 50%; transform: translateX(-50%);
  z-index: 9999; padding: 12px 24px;
  background: var(--color-primary); color: #fff;
  font-family: var(--font-heading); font-weight: 700;
  border-radius: 0 0 var(--radius) var(--radius);
  transition: top 0.2s;
}
.skip-to-content:focus { top: 0; }

/* === SCROLL PROGRESS === */
.scroll-progress {
  position: fixed; top: 0; left: 0; height: 3px;
  background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  z-index: 200; transform-origin: left; transform: scaleX(0);
  border-radius: 0 2px 2px 0;
}

/* === LAYOUT === */
.container {
  width: 100%; max-width: var(--max-width);
  margin: 0 auto; padding: 0 20px;
}
@media (min-width: 768px) { .container { padding: 0 48px; } }

.section-padding { padding: 56px 0; }
@media (min-width: 768px) { .section-padding { padding: 100px 0; } }

/* === TYPOGRAPHY === */
.heading-xl {
  font-size: calc(36px * var(--heading-scale));
  letter-spacing: -0.02em; line-height: 1.08;
}
@media (min-width: 768px) {
  .heading-xl { font-size: calc(60px * var(--heading-scale)); }
}
@media (min-width: 1024px) {
  .heading-xl { font-size: calc(76px * var(--heading-scale)); }
}

.heading-lg {
  font-size: calc(28px * var(--heading-scale));
  letter-spacing: -0.01em; line-height: 1.1;
}
@media (min-width: 768px) {
  .heading-lg { font-size: calc(48px * var(--heading-scale)); }
}

.heading-md {
  font-size: calc(24px * var(--heading-scale));
  line-height: 1.15;
}
@media (min-width: 768px) {
  .heading-md { font-size: calc(36px * var(--heading-scale)); }
}

.heading-sm {
  font-size: calc(18px * var(--heading-scale));
  font-weight: 600; line-height: 1.25;
}
@media (min-width: 768px) {
  .heading-sm { font-size: calc(22px * var(--heading-scale)); }
}

.text-muted { color: var(--color-text-muted); }
.text-sm { font-size: 14px; }
.text-xs { font-size: 12px; }

/* === BUTTONS === */
.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  padding: 16px 36px; min-height: 52px;
  font-family: var(--font-heading);
  font-size: 16px; font-weight: 700;
  border-radius: 100px; border: none;
  transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s ease;
  -webkit-tap-highlight-color: transparent;
  cursor: pointer; text-decoration: none;
}
.btn:hover { transform: scale(1.05); }
.btn:active { transform: scale(0.96); }

.btn--primary { background: var(--color-primary); color: #fff; }
.btn--primary:hover { box-shadow: 0 8px 25px rgba(255,107,53,0.4); }

.btn--secondary { background: var(--color-secondary); color: #fff; }
.btn--secondary:hover { box-shadow: 0 8px 25px rgba(27,73,101,0.3); }

.btn--ghost { background: rgba(27,73,101,0.08); color: var(--color-secondary); }
.btn--ghost:hover { background: rgba(27,73,101,0.14); }

.btn--outline { background: transparent; border: 2px solid var(--color-primary); color: var(--color-primary); }
.btn--outline:hover { background: var(--color-primary); color: #fff; }

.btn--cream { background: var(--color-bg); color: var(--color-text); }
.btn--cream:hover { box-shadow: 0 8px 25px rgba(255,248,240,0.3); }

.btn--mint { background: var(--color-mint); color: var(--color-text); }
.btn--mint:hover { box-shadow: 0 8px 25px rgba(6,214,160,0.3); }

.btn--sm { padding: 10px 24px; min-height: 44px; font-size: 14px; }

/* === STICKER BADGE === */
.sticker {
  display: inline-block;
  background: var(--color-accent); color: var(--color-text);
  font-family: var(--font-heading); font-weight: 700;
  font-size: 12px; padding: 5px 14px; border-radius: 100px;
  transform: rotate(-3deg);
  box-shadow: 2px 3px 0 rgba(0,0,0,0.08);
  letter-spacing: 0.02em;
}
.sticker--sm { font-size: 10px; padding: 4px 10px; }
@media (min-width: 768px) {
  .sticker { font-size: 13px; }
  .sticker--sm { font-size: 11px; padding: 5px 12px; }
}

/* === PRODUCT CARD === */
.product-card {
  display: block;
  background: var(--color-bg);
  border-radius: var(--radius);
  border: 3px solid rgba(26,26,46,0.06);
  box-shadow: 0 4px 20px rgba(26,26,46,0.06), inset 0 -2px 4px rgba(26,26,46,0.02);
  overflow: hidden;
  transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s ease;
  -webkit-tap-highlight-color: transparent;
  text-decoration: none; color: inherit;
}
.product-card:hover {
  transform: scale(1.03) rotate(0.5deg);
  box-shadow: 0 12px 40px rgba(255,107,53,0.15);
}
.product-card:active { transform: scale(0.97); }

.product-card__image {
  position: relative; overflow: hidden;
  aspect-ratio: 1; padding: 12px;
  display: flex; align-items: center; justify-content: center;
}
@media (min-width: 768px) { .product-card__image { padding: 16px; } }

.product-card__image img {
  width: 85%; height: auto; object-fit: contain;
  transition: transform 0.5s ease;
}
.product-card:hover .product-card__image img { transform: scale(1.1) rotate(2deg); }

.product-card__badge { position: absolute; top: 8px; right: 8px; }
@media (min-width: 768px) { .product-card__badge { top: 12px; right: 12px; } }

.product-card__info { padding: 12px; }
@media (min-width: 768px) { .product-card__info { padding: 20px; } }

.product-card__title {
  font-family: var(--font-heading); font-weight: 600;
  font-size: 14px; margin-bottom: 2px;
}
@media (min-width: 768px) { .product-card__title { font-size: 18px; margin-bottom: 4px; } }

.product-card__desc {
  font-size: 12px; color: var(--color-text-muted);
  margin-bottom: 8px; display: none;
}
@media (min-width: 768px) { .product-card__desc { display: block; font-size: 14px; margin-bottom: 12px; } }

.product-card__prices { display: flex; align-items: center; gap: 6px; }
.product-card__price {
  font-family: var(--font-heading); font-weight: 700;
  font-size: 16px; color: var(--color-primary);
}
@media (min-width: 768px) { .product-card__price { font-size: 20px; } }
.product-card__compare {
  font-size: 12px; color: var(--color-text-muted);
  text-decoration: line-through; opacity: 0.5;
}
@media (min-width: 768px) { .product-card__compare { font-size: 14px; } }

/* Card bg colors - alternating */
.product-card__image--peach { background: var(--color-bg-alt); }
.product-card__image--cream { background: #FFF5E6; }

/* === PRODUCT GRID === */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
@media (min-width: 1024px) {
  .product-grid { grid-template-columns: repeat(4, 1fr); gap: 24px; }
}

/* === MARQUEE === */
.marquee { overflow: hidden; white-space: nowrap; }
.marquee__track {
  display: inline-flex;
  animation: marquee-scroll 20s linear infinite;
}
@keyframes marquee-scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
.marquee__item {
  font-family: var(--font-heading); font-weight: 600;
  padding: 0 16px;
}
@media (min-width: 768px) { .marquee__item { padding: 0 24px; } }

/* === WAVY DIVIDER === */
.wave-divider {
  position: absolute; top: 0; left: 0; width: 100%;
  transform: translateY(-98%);
}
.wave-divider svg { display: block; width: 100%; height: 40px; }
@media (min-width: 768px) { .wave-divider svg { height: 80px; } }

/* === FLOATING ELEMENTS === */
.float-slow { animation: float-slow 4s ease-in-out infinite; }
.float-med { animation: float-med 3s ease-in-out infinite; }
@keyframes float-slow { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
@keyframes float-med { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }

.paw-decoration {
  position: absolute; opacity: 0.05;
  pointer-events: none; font-size: 36px;
}
@media (max-width: 767px) {
  .paw-decoration { display: none; }
  .float-slow, .float-med { animation: none; }
}

/* === ANNOUNCEMENT BAR === */
.announcement-bar {
  background: var(--color-accent);
  color: var(--color-text);
  font-family: var(--font-heading); font-weight: 700;
  font-size: 13px; text-align: center;
  padding: 8px 16px;
}

/* === HEADER === */
.header {
  position: fixed; top: 0; left: 0; width: 100%;
  z-index: 50; transition: all 0.3s ease;
}
.header--scrolled {
  background: rgba(255,248,240,0.95);
  backdrop-filter: blur(12px);
  box-shadow: 0 2px 20px rgba(0,0,0,0.05);
}
.header__inner {
  max-width: var(--max-width); margin: 0 auto;
  padding: 16px 20px;
  display: flex; align-items: center; justify-content: space-between;
}
@media (min-width: 768px) { .header__inner { padding: 16px 48px; } }

.header__logo {
  font-family: var(--font-heading); font-size: 20px; font-weight: 700;
  display: flex; align-items: center; gap: 8px;
}
@media (min-width: 768px) { .header__logo { font-size: 24px; } }

.header__nav { display: none; align-items: center; gap: 24px; }
@media (min-width: 768px) { .header__nav { display: flex; } }
.header__nav a {
  font-family: var(--font-body); font-size: 14px; font-weight: 600;
  color: var(--color-text-muted);
  transition: color 0.2s;
}
.header__nav a:hover { color: var(--color-text); }

.header__hamburger {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 5px; width: 44px; height: 44px;
  background: var(--color-bg-alt); border-radius: 50%;
}
@media (min-width: 768px) { .header__hamburger { display: none; } }
.header__hamburger span {
  display: block; height: 2px; background: var(--color-text);
  transition: all 0.3s ease;
}
.header__hamburger span:first-child { width: 20px; }
.header__hamburger span:last-child { width: 16px; }

/* Mobile menu */
.mobile-menu {
  position: fixed; inset: 0; z-index: 100;
  background: rgba(255,248,240,0.98);
  backdrop-filter: blur(20px);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 24px;
  opacity: 0; pointer-events: none;
  transition: opacity 0.3s ease;
}
.mobile-menu--open { opacity: 1; pointer-events: auto; }
.mobile-menu a {
  font-family: var(--font-heading);
  font-size: 24px; font-weight: 600;
  color: var(--color-text);
  transition: color 0.2s;
}
.mobile-menu a:hover { color: var(--color-primary); }

/* === FOOTER === */
.footer {
  background: var(--color-secondary);
  padding: 32px 0;
}
@media (min-width: 768px) { .footer { padding: 40px 0; } }
.footer__inner {
  max-width: var(--max-width); margin: 0 auto;
  padding: 0 20px;
  display: flex; flex-direction: column; align-items: center;
  gap: 12px;
}
@media (min-width: 768px) {
  .footer__inner {
    flex-direction: row; justify-content: space-between;
    padding: 0 48px; gap: 16px;
  }
}
.footer__logo {
  font-family: var(--font-heading); font-size: 16px; font-weight: 600;
  color: rgba(255,255,255,0.8);
}
@media (min-width: 768px) { .footer__logo { font-size: 18px; } }
.footer__links {
  display: flex; align-items: center; gap: 16px;
  font-size: 12px; color: rgba(255,255,255,0.4);
}
@media (min-width: 768px) { .footer__links { gap: 24px; font-size: 14px; } }
.footer__links a { transition: color 0.2s; min-height: 44px; display: flex; align-items: center; }
.footer__links a:hover { color: rgba(255,255,255,0.7); }

/* === CART DRAWER === */
.cart-drawer {
  position: fixed; top: 0; right: 0;
  width: 100%; max-width: 420px; height: 100vh;
  background: var(--color-bg); z-index: 200;
  transform: translateX(100%);
  transition: transform 0.4s cubic-bezier(0.25,0.1,0,1);
  box-shadow: -10px 0 40px rgba(0,0,0,0.1);
  display: flex; flex-direction: column;
}
.cart-drawer--open { transform: translateX(0); }
.cart-drawer__overlay {
  position: fixed; inset: 0; z-index: 199;
  background: rgba(0,0,0,0.4);
  opacity: 0; pointer-events: none;
  transition: opacity 0.3s ease;
}
.cart-drawer__overlay--open { opacity: 1; pointer-events: auto; }

.cart-drawer__header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px; border-bottom: 2px solid rgba(26,26,46,0.06);
}
.cart-drawer__header h2 {
  font-family: var(--font-heading); font-size: 20px; font-weight: 700;
}
.cart-drawer__close {
  width: 44px; height: 44px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%; background: var(--color-bg-alt);
  font-size: 18px;
}

.cart-drawer__items { flex: 1; overflow-y: auto; padding: 20px; }
.cart-drawer__empty {
  text-align: center; padding: 60px 20px;
  font-family: var(--font-heading); color: var(--color-text-muted);
}

.cart-drawer__footer {
  padding: 20px;
  border-top: 2px solid rgba(26,26,46,0.06);
}
.cart-drawer__subtotal {
  display: flex; justify-content: space-between;
  font-family: var(--font-heading); font-weight: 700;
  font-size: 18px; margin-bottom: 16px;
}

/* === CART ITEM === */
.cart-item {
  display: flex; gap: 16px;
  padding: 16px 0;
  border-bottom: 1px solid rgba(26,26,46,0.06);
}
.cart-item__image {
  width: 80px; height: 80px; flex-shrink: 0;
  background: var(--color-bg-alt);
  border-radius: 12px; overflow: hidden;
}
.cart-item__image img { width: 100%; height: 100%; object-fit: cover; }
.cart-item__info { flex: 1; }
.cart-item__title { font-family: var(--font-heading); font-weight: 600; font-size: 15px; margin-bottom: 4px; }
.cart-item__price { font-family: var(--font-heading); font-weight: 700; color: var(--color-primary); }
.cart-item__qty {
  display: flex; align-items: center; gap: 12px; margin-top: 8px;
}
.cart-item__qty button {
  width: 32px; height: 32px;
  border-radius: 50%; border: 2px solid rgba(26,26,46,0.1);
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 16px;
}

/* === PRODUCT PAGE === */
.product-page { padding-top: 80px; }
.product-page__grid {
  display: grid; grid-template-columns: 1fr;
  gap: 24px;
}
@media (min-width: 768px) {
  .product-page__grid { grid-template-columns: 1fr 1fr; gap: 48px; }
}

.product-page__gallery { position: relative; }
.product-page__main-image {
  border-radius: var(--radius);
  overflow: hidden; background: var(--color-bg-alt);
}
.product-page__main-image img { width: 100%; height: auto; object-fit: contain; padding: 16px; }

.product-page__thumbnails {
  display: flex; gap: 8px; margin-top: 12px; overflow-x: auto;
  -ms-overflow-style: none; scrollbar-width: none;
}
.product-page__thumbnails::-webkit-scrollbar { display: none; }
.product-page__thumb {
  width: 64px; height: 64px; flex-shrink: 0;
  border-radius: 12px; overflow: hidden;
  border: 2px solid transparent;
  background: var(--color-bg-alt); cursor: pointer;
  transition: border-color 0.2s;
}
.product-page__thumb--active,
.product-page__thumb:hover { border-color: var(--color-primary); }
.product-page__thumb img { width: 100%; height: 100%; object-fit: contain; padding: 4px; }

.product-page__info { padding: 16px 0; }
@media (min-width: 768px) { .product-page__info { padding: 24px 0; } }

.product-page__vendor {
  font-family: var(--font-heading); font-size: 14px; font-weight: 700;
  color: var(--color-primary); letter-spacing: 0.1em;
  text-transform: uppercase; margin-bottom: 8px;
}

.product-page__title {
  font-size: calc(28px * var(--heading-scale));
  letter-spacing: -0.01em; margin-bottom: 12px;
}
@media (min-width: 768px) {
  .product-page__title { font-size: calc(40px * var(--heading-scale)); }
}

.product-page__price-row {
  display: flex; align-items: center; gap: 12px;
  margin-bottom: 20px;
}
.product-page__price {
  font-family: var(--font-heading); font-size: 28px; font-weight: 700;
  color: var(--color-primary);
}
.product-page__compare-price {
  font-size: 18px; color: var(--color-text-muted);
  text-decoration: line-through; opacity: 0.5;
}

.product-page__desc {
  color: var(--color-text-muted); line-height: 1.7;
  margin-bottom: 24px; max-width: 540px;
}

.product-page__variants { margin-bottom: 20px; }
.product-page__variant-label {
  font-family: var(--font-heading); font-weight: 600;
  font-size: 14px; margin-bottom: 8px;
}
.product-page__variant-options { display: flex; flex-wrap: wrap; gap: 8px; }
.product-page__variant-btn {
  padding: 10px 20px; min-height: 44px;
  border-radius: 100px; border: 2px solid rgba(26,26,46,0.1);
  font-family: var(--font-heading); font-weight: 600; font-size: 14px;
  transition: all 0.2s;
}
.product-page__variant-btn:hover,
.product-page__variant-btn--selected {
  border-color: var(--color-primary);
  background: rgba(255,107,53,0.08);
  color: var(--color-primary);
}

.product-page__add-to-cart {
  width: 100%; max-width: 400px; margin-bottom: 16px;
}

.product-page__guarantees {
  display: flex; flex-wrap: wrap; gap: 16px;
  margin-top: 20px; padding-top: 20px;
  border-top: 2px solid rgba(26,26,46,0.06);
}
.product-page__guarantee {
  display: flex; align-items: center; gap: 8px;
  font-size: 13px; color: var(--color-text-muted);
}

/* === COLLECTION PAGE === */
.collection-page { padding-top: 80px; }
.collection-page__header {
  text-align: center;
  padding: 40px 0;
}
@media (min-width: 768px) { .collection-page__header { padding: 60px 0; } }

/* === GENERIC PAGE === */
.page-content {
  padding-top: 100px;
  max-width: 720px; margin: 0 auto;
}
.page-content h1 { margin-bottom: 24px; }
.page-content p { margin-bottom: 16px; color: var(--color-text-muted); line-height: 1.7; }

/* === 404 === */
.error-404 {
  min-height: 60vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center; padding: 40px 20px;
}
.error-404__emoji { font-size: 64px; margin-bottom: 16px; }

/* === CONTACT FORM === */
.contact-form { max-width: 560px; margin: 0 auto; }
.form-group { margin-bottom: 16px; }
.form-label {
  display: block; font-family: var(--font-heading);
  font-weight: 600; font-size: 14px;
  margin-bottom: 6px;
}
.form-input,
.form-textarea {
  width: 100%; padding: 14px 20px;
  border: 2px solid rgba(26,26,46,0.1);
  border-radius: var(--radius);
  font-family: var(--font-body); font-size: 16px;
  background: #fff;
  transition: border-color 0.2s;
}
.form-input:focus,
.form-textarea:focus {
  outline: none;
  border-color: var(--color-primary);
}
.form-textarea { min-height: 140px; resize: vertical; }

/* === UTILITY === */
.visually-hidden {
  position: absolute; width: 1px; height: 1px;
  padding: 0; margin: -1px; overflow: hidden;
  clip: rect(0,0,0,0); border: 0;
}

/* Hide scroll progress if disabled */
{% unless settings.show_scroll_progress %}
.scroll-progress { display: none; }
{% endunless %}
