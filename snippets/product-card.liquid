{%- comment -%}
  Renders a product card.
  Accepts:
  - product: {Object} Product Liquid object
  - index: {Number} Index for alternating bg
{%- endcomment -%}

<a href="{{ product.url }}" class="product-card group">
  <div class="product-card__image {% cycle 'product-card__image--peach', 'product-card__image--cream' %}">
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        width="600"
        height="600"
        loading="lazy"
      >
    {%- else -%}
      <div style="width:60%;aspect-ratio:1;background:rgba(26,26,46,0.05);border-radius:12px;"></div>
    {%- endif -%}

    {%- if product.compare_at_price > product.price -%}
      <div class="product-card__badge">
        <span class="sticker sticker--sm">
          {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}% OFF
        </span>
      </div>
    {%- endif -%}
  </div>

  <div class="product-card__info">
    <h3 class="product-card__title">{{ product.title }}</h3>
    <p class="product-card__desc">{{ product.metafields.custom.short_description | default: product.type }}</p>
    <div class="product-card__prices">
      <span class="product-card__price">{{ product.price | money }}</span>
      {%- if product.compare_at_price > product.price -%}
        <span class="product-card__compare">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>
  </div>
</a>
