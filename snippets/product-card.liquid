{%- comment -%}
  Renders a product card.
  Accepts:
  - product: {Object} Product Liquid object
{%- endcomment -%}

{%- if product != blank -%}
<a href="{{ product.url }}" class="product-card group">
  <div class="product-card__image {% if index %}{% cycle 'product-card__image--peach', 'product-card__image--cream' %}{% else %}product-card__image--peach{% endif %}">
    {%- if product.featured_image != blank -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        width="600"
        height="600"
        loading="lazy"
      >
    {%- else -%}
      <div style="width:60%;aspect-ratio:1;background:rgba(26,26,46,0.05);border-radius:12px;"></div>
    {%- endif -%}

    {%- if product.compare_at_price and product.compare_at_price > product.price -%}
      <div class="product-card__badge">
        <span class="sticker sticker--sm">Sale</span>
      </div>
    {%- endif -%}
  </div>

  <div class="product-card__info">
    <h3 class="product-card__title">{{ product.title }}</h3>
    <p class="product-card__desc">{{ product.type }}</p>
    <div class="product-card__prices">
      <span class="product-card__price">{{ product.price | money }}</span>
      {%- if product.compare_at_price and product.compare_at_price > product.price -%}
        <span class="product-card__compare">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>
  </div>
</a>
{%- endif -%}
