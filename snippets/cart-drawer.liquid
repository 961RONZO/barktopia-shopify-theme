<!-- Cart overlay -->
<div class="cart-drawer__overlay" id="cartOverlay"></div>

<!-- Cart drawer -->
<div class="cart-drawer" id="cartDrawer">
  <div class="cart-drawer__header">
    <h2>🛒 {{ 'cart.general.title' | t }}</h2>
    <button class="cart-drawer__close" aria-label="{{ 'accessibility.close' | t }}">✕</button>
  </div>

  <div class="cart-drawer__items">
    {%- if cart.items.size > 0 -%}
      {%- for item in cart.items -%}
        <div class="cart-item">
          <div class="cart-item__image">
            {%- if item.image -%}
              <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" loading="lazy">
            {%- endif -%}
          </div>
          <div class="cart-item__info">
            <p class="cart-item__title">{{ item.product.title }}</p>
            {%- if item.variant.title != 'Default Title' -%}
              <p class="text-sm text-muted">{{ item.variant.title }}</p>
            {%- endif -%}
            <p class="cart-item__price">{{ item.final_line_price | money }}</p>
            <div class="cart-item__qty">
              <button onclick="updateCartItem('{{ item.key }}', {{ item.quantity | minus: 1 }})">−</button>
              <span>{{ item.quantity }}</span>
              <button onclick="updateCartItem('{{ item.key }}', {{ item.quantity | plus: 1 }})">+</button>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="cart-drawer__empty">
        <p style="font-size:48px;margin-bottom:12px;">🛒</p>
        <p>{{ 'cart.general.empty' | t }}</p>
      </div>
    {%- endif -%}
  </div>

  <div class="cart-drawer__footer">
    <div class="cart-drawer__subtotal">
      <span>{{ 'cart.general.subtotal' | t }}</span>
      <span class="cart-drawer__subtotal-price">{{ cart.total_price | money }}</span>
    </div>
    {%- if cart.items.size > 0 -%}
      <a href="/checkout" class="btn btn--primary" style="width:100%;">{{ 'cart.general.checkout' | t }}</a>
    {%- else -%}
      <a href="/collections/all" class="btn btn--outline" style="width:100%;">{{ 'cart.general.continue_shopping' | t }}</a>
    {%- endif -%}
  </div>
</div>
