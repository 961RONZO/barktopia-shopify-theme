<header class="header" id="siteHeader">
  <div class="header__inner">
    <a href="/" class="header__logo">
      {%- if section.settings.logo -%}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" style="height:{{ section.settings.logo_height }}px;">
      {%- else -%}
        <span>🐾</span> {{ shop.name }}
      {%- endif -%}
    </a>

    <nav class="header__nav">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}

      <button class="btn btn--primary btn--sm" data-cart-trigger>
        🛒 Cart
        <span data-cart-count style="{% if cart.item_count == 0 %}display:none{% endif %}">
          ({{ cart.item_count }})
        </span>
      </button>
    </nav>

    <button class="header__hamburger" aria-label="{{ 'accessibility.menu' | t }}">
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu">
  {%- for link in section.settings.menu.links -%}
    <a href="{{ link.url }}">{{ link.title }}</a>
  {%- endfor -%}
  <button class="btn btn--primary" data-cart-trigger style="margin-top:16px;">🛒 Cart ({{ cart.item_count }})</button>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
