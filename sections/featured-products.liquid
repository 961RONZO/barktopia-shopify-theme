<section class="section-padding" style="background:var(--color-bg);">
  <div class="container">
    <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:40px;">
      {%- if section.settings.badge_text != blank -%}
        <div class="animate-bounce-in"><span class="sticker">{{ section.settings.badge_text }}</span></div>
      {%- endif -%}
      <div style="display:flex;align-items:flex-end;justify-content:space-between;">
        <h2 class="heading-lg animate-title">{{ section.settings.heading }}</h2>
        {%- if section.settings.view_all_link != blank -%}
          <a href="{{ section.settings.view_all_link }}" style="font-family:var(--font-body);font-weight:700;color:var(--color-primary);font-size:14px;display:flex;align-items:center;gap:8px;min-height:44px;white-space:nowrap;">
            {{ section.settings.view_all_text | default: 'View All' }}
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="product-grid animate-stagger">
      {%- if section.settings.collection != blank -%}
        {%- for product in collections[section.settings.collection].products limit: section.settings.products_count -%}
          {% render 'product-card', product: product, index: forloop.index %}
        {%- endfor -%}
      {%- else -%}
        {%- for product in shop.products limit: section.settings.products_count -%}
          {% render 'product-card', product: product, index: forloop.index %}
        {%- endfor -%}
      {%- endif -%}

      {%- if section.settings.show_cta_card -%}
        <div style="background:var(--color-bg-alt);border-radius:var(--radius);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px;text-align:center;">
          <div style="font-size:48px;margin-bottom:12px;">🎁</div>
          <h3 style="font-family:var(--font-heading);font-weight:600;font-size:16px;margin-bottom:8px;">{{ section.settings.cta_heading }}</h3>
          <p style="font-size:13px;color:var(--color-text-muted);margin-bottom:16px;">{{ section.settings.cta_description }}</p>
          <a href="{{ section.settings.cta_link }}" class="btn btn--primary btn--sm">{{ section.settings.cta_button }}</a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "🔥 Best Sellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Toys They'll Obsess Over"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 7
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    },
    {
      "type": "header",
      "content": "CTA Card"
    },
    {
      "type": "checkbox",
      "id": "show_cta_card",
      "label": "Show CTA card at end",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA heading",
      "default": "Want them all?"
    },
    {
      "type": "text",
      "id": "cta_description",
      "label": "CTA description",
      "default": "Visit our store for bundles & deals"
    },
    {
      "type": "text",
      "id": "cta_button",
      "label": "CTA button text",
      "default": "Shop All"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
