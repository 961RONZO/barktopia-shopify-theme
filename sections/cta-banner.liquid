<section style="position:relative;background:{{ section.settings.bg_color }};padding:64px 0;overflow:hidden;">
  <div class="wave-divider">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
      <path d="M0,80 C240,30 480,70 720,25 C960,0 1200,50 1440,30 L1440,80 Z" fill="{{ section.settings.bg_color }}"/>
    </svg>
  </div>

  <div class="paw-decoration float-slow" style="top:10%;left:8%;color:{{ section.settings.text_color }};">🐾</div>
  <div class="paw-decoration float-med" style="bottom:15%;right:8%;color:{{ section.settings.text_color }};font-size:50px;">🦴</div>

  <div class="container" style="text-align:center;position:relative;z-index:1;">
    <h2 class="heading-lg animate-title" style="color:{{ section.settings.text_color }};margin-bottom:16px;">
      {{ section.settings.heading }}
    </h2>
    <p style="color:{{ section.settings.text_color }};opacity:0.7;font-size:16px;max-width:500px;margin:0 auto 32px;line-height:1.65;">
      {{ section.settings.description }}
    </p>
    {%- if section.settings.button_text != blank -%}
      <a href="{{ section.settings.button_link }}" class="btn btn--cream" style="font-size:16px;padding:18px 40px;">
        {{ section.settings.button_text }}
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    {%- endif -%}
  </div>

  <style>
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }} > section { padding: 128px 0 !important; }
      #shopify-section-{{ section.id }} p { font-size: 20px !important; margin-bottom: 40px !important; }
    }
  </style>
</section>

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Dog's New Favorite Toy Is One Click Away"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Free shipping. Safe materials. Happy tails guaranteed."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Explore Barktopia"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FF6B35"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "CTA Banner"
    }
  ]
}
{% endschema %}
