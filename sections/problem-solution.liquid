<section style="position:relative;background:{{ section.settings.bg_color }};padding:56px 0;overflow:hidden;">
  <!-- Wave divider -->
  <div class="wave-divider">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
      <path d="M0,80 C320,20 640,70 960,30 C1120,10 1280,50 1440,30 L1440,80 Z" fill="{{ section.settings.bg_color }}"/>
    </svg>
  </div>

  <div class="container" style="text-align:center;position:relative;z-index:1;">
    <h2 class="heading-lg animate-title" style="color:{{ section.settings.text_color }};margin-bottom:20px;">
      {{ section.settings.heading }}
    </h2>
    {%- if section.settings.description != blank -%}
      <p style="color:{{ section.settings.text_color }};opacity:0.7;font-size:16px;max-width:640px;margin:0 auto 40px;line-height:1.65;">
        {{ section.settings.description }}
      </p>
    {%- endif -%}

    <div class="animate-stagger" style="display:grid;grid-template-columns:1fr;gap:16px;">
      {%- for block in section.blocks -%}
        <div style="background:rgba(255,255,255,0.15);backdrop-filter:blur(8px);border-radius:var(--radius);padding:20px;text-align:center;">
          <div style="font-size:36px;margin-bottom:12px;">{{ block.settings.icon }}</div>
          <h3 style="font-family:var(--font-heading);font-weight:600;font-size:16px;color:{{ section.settings.text_color }};margin-bottom:8px;">{{ block.settings.title }}</h3>
          <p style="font-size:14px;color:{{ section.settings.text_color }};opacity:0.6;line-height:1.6;">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>

  <style>
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }} > section { padding: 100px 0; }
      #shopify-section-{{ section.id }} .animate-stagger { grid-template-columns: repeat({{ section.blocks.size }}, 1fr) !important; gap: 24px !important; }
      #shopify-section-{{ section.id }} .heading-lg { margin-bottom: 32px !important; }
      #shopify-section-{{ section.id }} p { font-size: 20px !important; margin-bottom: 56px !important; }
    }
  </style>
</section>

{% schema %}
{
  "name": "Problem / Solution",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "When Dogs Get Bored, Problems Begin."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Chewed shoes. Endless barking. Separation anxiety. Your dog isn't bad — they're bored. Barktopia enrichment toys fix that."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FF6B35"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji icon",
          "default": "🧠"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Mental Stimulation"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Puzzles and foraging toys that challenge their brain and reward curiosity."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Problem / Solution",
      "blocks": [
        { "type": "card", "settings": { "icon": "🧠", "title": "Mental Stimulation", "description": "Puzzles and foraging toys that challenge their brain and reward curiosity." } },
        { "type": "card", "settings": { "icon": "🍽️", "title": "Slower Eating", "description": "Lick mats and puzzle feeders turn 30-second meals into 15-minute activities." } },
        { "type": "card", "settings": { "icon": "😌", "title": "Calmer Behavior", "description": "An enriched dog is a happy, calm dog. Less barking, less chewing, less anxiety." } }
      ]
    }
  ]
}
{% endschema %}
